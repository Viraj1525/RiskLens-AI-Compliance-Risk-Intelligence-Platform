# Copy to `.env` (local dev) or `.env.production` (Docker / production) and fill in real values.
# Never commit files that contain real API keys.

GROQ_API_KEY=your_groq_api_key
GROQ_MODEL_NAME=llama-3.3-70b-versatile
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
EMBEDDING_MODEL_OFFLINE=false
# EMBEDDING_MODEL_CACHE_DIR=D:\models\sentence-transformers

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

API_HOST=127.0.0.1
API_PORT=8000

# Comma-separated if multiple origins. For Docker desktop testing use http://localhost:8080
FRONTEND_DEV_URL=http://127.0.0.1:5173
ALLOWED_ORIGINS=http://127.0.0.1:5173

# Vite (used at dev and at frontend image build time)
VITE_API_BASE_URL=/api
VITE_API_PROXY_TARGET=http://127.0.0.1:8000
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

APP_ENV=development
